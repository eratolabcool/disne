</style>

<script is:inline>window.__GAME_SLUG__ = "{gameSlug}";</script>
<script is:inline src="/game-bridge.js"></script>
<script is:inline type="module" src="/main.js"></script>
<script is:inline>
  // ── 房间 UI 绑定 ─────────────────────────────────────────
  document.getElementById('btn-create-room')?.addEventListener('click', async function() {
    var result = await window.solitaireArena._rooms.create(window.__GAME_SLUG__);
    if (!result) return;
    var statusEl = document.getElementById('vs-status');
    if (statusEl) statusEl.innerHTML = '<span style="color:#d4af37">Room: ' + result.code + '</span><br><span style="color:#5a6a5e;font-size:11px">Share this code with your opponent</span>';
    document.getElementById('btn-start-room').style.display = 'block';
    // 同时加入自己
    await window.solitaireArena._rooms.join(result.code);
  });

  document.getElementById('btn-join-room')?.addEventListener('click', async function() {
    var code = document.getElementById('inp-room-code')?.value.toUpperCase().trim();
    if (!code || code.length !== 6) { alert('Enter a 6-character room code'); return; }
    var result = await window.solitaireArena._rooms.join(code);
    if (!result) return;
    var statusEl = document.getElementById('vs-status');
    if (statusEl) statusEl.innerHTML = '<span style="color:#d4af37">Joined room: ' + code + '</span><br><span style="color:#5a6a5e;font-size:11px">Waiting for host to start...</span>';
  });

  document.getElementById('btn-start-room')?.addEventListener('click', async function() {
    await window.solitaireArena._rooms.start();
    document.getElementById('btn-start-room').style.display = 'none';
    var statusEl = document.getElementById('vs-status');
    if (statusEl) statusEl.innerHTML = '<span style="color:#2d6a4f">Game started! Good luck!</span>';
  });
</script>
