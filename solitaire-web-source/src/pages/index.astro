---
/**
 * [INPUT]: 依赖 Layout.astro, config/site.ts (GAMES, COLORS, siteConfig)
 * [OUTPUT]: 首页 HTML — Hero + 三张游戏卡片 + 模式入口
 * [POS]: pages/index.astro 是站点首页
 * [PROTOCOL]: 变更时更新此头部，然后检查 CLAUDE.md
 */
import Layout from '../layouts/Layout.astro';
import { GAMES, COLORS, siteConfig } from '../config/site';
---

<Layout title="Solitaire Arena — 在线纸牌竞技" description="Klondike · Spider · FreeCell 三大经典纸牌。每日挑战、计时竞速、闯关模式，全球排行。">
  <!-- ============================================================ -->
  <!-- HERO                                                          -->
  <!-- ============================================================ -->
  <section class="hero" id="hero">
    <div class="hero-bg"><div class="hero-gradient"></div></div>
    <div class="hero-content fade-in-up">
      <div class="hero-badge">♠ 三大经典 · 全球竞技</div>
      <h1 class="hero-title">
        <span class="hero-title-line">Welcome to</span>
        <span class="hero-title-accent">Solitaire Arena</span>
      </h1>
      <p class="hero-subtitle">
        Klondike · Spider · FreeCell — 每日挑战、计时竞速、闯关模式，与全球玩家一决高下。
      </p>
      <div class="hero-actions">
        <a href="#games" class="btn btn-primary">选择游戏</a>
        <a href="#modes" class="btn btn-secondary">游戏模式</a>
      </div>
      <div class="hero-stats">
        <div class="stat"><span class="stat-value">3</span><span class="stat-label">经典纸牌</span></div>
        <div class="stat"><span class="stat-value">4</span><span class="stat-label">游戏模式</span></div>
        <div class="stat"><span class="stat-value">∞</span><span class="stat-label">免费畅玩</span></div>
      </div>
    </div>
  </section>

  <!-- ============================================================ -->
  <!-- 三大游戏卡片                                                   -->
  <!-- ============================================================ -->
  <section class="game-section" id="games">
    <div class="section-inner">
      <div class="section-header">
        <h2 class="section-title"><span class="title-icon">♠</span> 选择游戏</h2>
      </div>
      <div class="games-grid">
        {GAMES.map((game, i) => (
          <a href={`/play/${game.slug}`} class={`game-card fade-in-up fade-in-up-delay-${(i % 3) + 1}`}>
            <div class="card-game-icon" style={`--card-color: ${game.color}`}>
              <span class="icon-emoji">{game.icon}</span>
            </div>
            <div class="card-info">
              <h3 class="card-title">{game.name}</h3>
              <p class="card-desc">{game.description}</p>
            </div>
            <div class="card-footer">
              <span class="mode-tag">自由模式</span>
              <span class="mode-tag">每日挑战</span>
              <span class="mode-tag">计时竞速</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================================================ -->
  <!-- 游戏模式                                                       -->
  <!-- ============================================================ -->
  <section class="modes-section" id="modes">
    <div class="section-inner">
      <div class="section-header">
        <h2 class="section-title"><span class="title-icon">🏆</span> 游戏模式</h2>
      </div>
      <div class="modes-grid">
        <div class="mode-card">
          <div class="mode-icon">🎯</div>
          <h3>每日挑战</h3>
          <p>全球同局，同一种子。每天 Klondike / Spider / FreeCell 各一局，综合评分排名。</p>
        </div>
        <div class="mode-card">
          <div class="mode-icon">⏱️</div>
          <h3>计时竞速</h3>
          <p>正常随机牌局，独立计时。挑战最快通关时间，排行榜分游戏类型+难度。</p>
        </div>
        <div class="mode-card">
          <div class="mode-icon">🗺️</div>
          <h3>闯关模式</h3>
          <p>200 关预设牌局，按 Chapter 推进。三星评价系统，Boss 关步数限制。</p>
        </div>
        <div class="mode-card">
          <div class="mode-icon">🃏</div>
          <h3>自由模式</h3>
          <p>经典纸牌，随意畅玩。无排名、无限制，享受纯粹的纸牌乐趣。</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================ -->
  <!-- CTA                                                           -->
  <!-- ============================================================ -->
  <section class="cta-banner">
    <div class="section-inner">
      <div class="cta-content">
        <div class="cta-text">
          <h2>♠ 准备好了吗？</h2>
          <p>选择你最喜欢的纸牌游戏，开始挑战吧。零下载，零注册，完全免费。</p>
        </div>
        <a href={`/play/${GAMES[0].slug}`} class="btn btn-primary btn-lg">开始游戏</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* ============ HERO ============ */
  .hero {
    position: relative;
    min-height: 480px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    padding: 80px 24px 60px;
  }

  .hero-bg { position: absolute; inset: 0; z-index: 0; }
  .hero-gradient {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, #1a472a 0%, #0d2818 40%, #0a0f0d 100%);
    opacity: 0.97;
  }

  .hero-content {
    position: relative;
    z-index: 1;
    text-align: center;
    max-width: 720px;
  }

  .hero-badge {
    display: inline-block;
    padding: 6px 18px;
    background: rgba(212,175,55,0.15);
    border: 1px solid rgba(212,175,55,0.3);
    border-radius: 100px;
    font-size: 14px;
    font-weight: 600;
    color: var(--sol-gold, #d4af37);
    margin-bottom: 24px;
    letter-spacing: 0.5px;
  }

  .hero-title { margin-bottom: 20px; }
  .hero-title-line {
    display: block;
    font-size: clamp(22px, 4vw, 32px);
    font-weight: 600;
    color: rgba(232,224,208,0.8);
    margin-bottom: 4px;
  }
  .hero-title-accent {
    display: block;
    font-size: clamp(40px, 7vw, 72px);
    font-weight: 900;
    background: linear-gradient(135deg, #e8e0d0 0%, #d4af37 50%, #b8960c 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    letter-spacing: -2px;
    line-height: 1.1;
  }
  .hero-subtitle {
    font-size: clamp(15px, 2vw, 18px);
    color: rgba(232,224,208,0.6);
    max-width: 560px;
    margin: 0 auto 32px;
    line-height: 1.7;
  }
  .hero-actions { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; margin-bottom: 40px; }

  /* Buttons */
  .btn {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 14px 28px; border-radius: 10px;
    font-weight: 600; font-size: 16px;
    transition: all 250ms cubic-bezier(0.4,0,0.2,1);
    cursor: pointer; text-decoration: none; border: none;
  }
  .btn-primary {
    background: #1a472a; color: #e8e0d0;
    border: 1px solid #2d6a4f;
  }
  .btn-primary:hover {
    background: #2d6a4f;
    transform: translateY(-2px);
    box-shadow: 0 4px 20px rgba(26,71,42,0.5);
  }
  .btn-secondary {
    background: rgba(232,224,208,0.08);
    color: #e8e0d0;
    border: 1px solid rgba(232,224,208,0.15);
  }
  .btn-secondary:hover {
    background: rgba(232,224,208,0.15);
    transform: translateY(-2px);
  }
  .btn-lg { padding: 16px 36px; font-size: 18px; }

  .hero-stats { display: flex; gap: 40px; justify-content: center; flex-wrap: wrap; }
  .stat { text-align: center; }
  .stat-value {
    display: block;
    font-family: 'Outfit', sans-serif;
    font-size: 28px; font-weight: 800; color: #d4af37;
  }
  .stat-label { font-size: 13px; color: rgba(232,224,208,0.5); text-transform: uppercase; letter-spacing: 1px; }

  /* ============ SECTIONS ============ */
  .section-inner { max-width: 1200px; margin: 0 auto; padding: 0 24px; }
  .section-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 24px; }
  .section-title { display: flex; align-items: center; gap: 10px; font-size: 24px; font-weight: 700; }
  .title-icon { font-size: 28px; line-height: 1; }

  .game-section { padding: 48px 0; }
  .games-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 24px;
  }

  /* ============ GAME CARD ============ */
  .game-card {
    display: flex; flex-direction: column;
    background: var(--bg-card, #162219);
    border: 1px solid var(--border, #1e2e24);
    border-radius: 16px;
    overflow: hidden;
    transition: all 250ms cubic-bezier(0.4,0,0.2,1);
    text-decoration: none; cursor: pointer;
  }
  .game-card:hover {
    border-color: #2d6a4f;
    transform: translateY(-4px);
    box-shadow: 0 8px 32px rgba(26,71,42,0.3);
  }

  .card-game-icon {
    display: flex; align-items: center; justify-content: center;
    height: 180px;
    background: linear-gradient(135deg, var(--card-color), rgba(0,0,0,0.3));
  }
  .icon-emoji { font-size: 64px; }

  .card-info { padding: 20px; flex: 1; }
  .card-title { font-size: 22px; font-weight: 700; color: var(--text-primary, #e8e0d0); margin-bottom: 8px; }
  .card-desc { font-size: 14px; color: var(--text-secondary, #8a9a8e); line-height: 1.6; }

  .card-footer {
    display: flex; gap: 8px; padding: 0 20px 20px;
    flex-wrap: wrap;
  }
  .mode-tag {
    padding: 4px 12px;
    background: rgba(212,175,55,0.1);
    border: 1px solid rgba(212,175,55,0.2);
    border-radius: 100px;
    font-size: 12px; font-weight: 500;
    color: #d4af37;
  }

  /* ============ MODES ============ */
  .modes-section { padding: 48px 0; border-top: 1px solid var(--border, #1e2e24); }
  .modes-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
    gap: 20px;
  }
  .mode-card {
    padding: 24px;
    background: var(--bg-card, #162219);
    border: 1px solid var(--border, #1e2e24);
    border-radius: 14px;
    transition: all 200ms;
  }
  .mode-card:hover {
    border-color: #2d6a4f;
    box-shadow: 0 4px 20px rgba(26,71,42,0.2);
  }
  .mode-icon { font-size: 36px; margin-bottom: 12px; }
  .mode-card h3 { font-size: 18px; font-weight: 700; margin-bottom: 8px; color: var(--text-primary, #e8e0d0); }
  .mode-card p { font-size: 14px; color: var(--text-secondary, #8a9a8e); line-height: 1.6; }

  /* ============ CTA ============ */
  .cta-banner { padding: 48px 0; }
  .cta-content {
    background: linear-gradient(135deg, #1a472a 0%, #0d2818 50%, #0a0f0d 100%);
    border: 1px solid #2d6a4f;
    border-radius: 20px;
    padding: 48px;
    display: flex; align-items: center; justify-content: space-between; gap: 32px;
  }
  .cta-text h2 { font-size: 28px; color: #e8e0d0; margin-bottom: 8px; }
  .cta-text p { color: rgba(232,224,208,0.7); font-size: 16px; }
  .cta-content .btn-primary {
    background: #d4af37; color: #0a0f0d;
    white-space: nowrap; flex-shrink: 0;
    border: none;
  }
  .cta-content .btn-primary:hover {
    background: #e8c84a;
    box-shadow: 0 4px 20px rgba(212,175,55,0.4);
  }

  /* ============ ANIMATIONS ============ */
  .fade-in-up { animation: fadeInUp 600ms ease-out both; }
  .fade-in-up-delay-1 { animation-delay: 100ms; }
  .fade-in-up-delay-2 { animation-delay: 200ms; }
  .fade-in-up-delay-3 { animation-delay: 300ms; }

  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* ============ RESPONSIVE ============ */
  @media (max-width: 768px) {
    .hero { min-height: 380px; padding: 60px 20px 40px; }
    .hero-stats { gap: 24px; }
    .stat-value { font-size: 22px; }
    .games-grid { grid-template-columns: 1fr; }
    .modes-grid { grid-template-columns: 1fr; }
    .cta-content { flex-direction: column; text-align: center; padding: 32px 24px; }
  }
</style>
