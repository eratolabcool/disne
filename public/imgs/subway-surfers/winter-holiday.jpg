<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 400 300" width="400" height="300">
  <rect width="400" height="300" fill="#0d47a1"/>
  <g transform="translate(200, 80)">
    <!-- 雪花背景 -->
    <circle cx="-80" cy="-40" r="5" fill="white" opacity="0.8"/>
    <circle cx="-60" cy="-20" r="3" fill="white" opacity="0.6"/>
    <circle cx="-40" cy="-50" r="4" fill="white" opacity="0.7"/>
    <circle cx="-20" cy="-30" r="6" fill="white" opacity="0.8"/>
    <circle cx="0" cy="-60" r="5" fill="white" opacity="0.7"/>
    <circle cx="20" cy="-40" r="3" fill="white" opacity="0.6"/>
    <circle cx="40" cy="-20" r="4" fill="white" opacity="0.8"/>
    <circle cx="60" cy="-50" r="6" fill="white" opacity="0.7"/>
    <circle cx="80" cy="-30" r="5" fill="white" opacity="0.6"/>
    
    <!-- 角色 -->
    <path d="M-30,-10 L30,-10 L0,-50 Z" fill="#f44336"/>
    <circle cx="0" cy="20" r="30" fill="#f44336"/>
    <circle cx="-15" cy="10" r="5" fill="#000"/>
    <circle cx="15" cy="10" r="5" fill="#000"/>
    <path d="M-15,30 Q0,40 15,30" stroke="#000" stroke-width="3" fill="none"/>
    
    <!-- 圣诞帽 -->
    <path d="M-20,-30 Q0,-60 20,-30 L-20,-30 Z" fill="#f44336"/>
    <circle cx="20" cy="-30" r="8" fill="white"/>
  </g>
  <text x="200" y="180" font-family="Arial" font-size="24" fill="white" text-anchor="middle" font-weight="bold">WINTER HOLIDAY</text>
</svg>